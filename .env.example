BOT_TOKEN=your_bot_token_here
# Optional: bypass keyword to allow more verses (e.g., "مميز")
BYPASS_KEYWORD=مميز
# PocketBase for activity tracking (leave empty to disable)
POCKETBASE_URL=https://db.example.com
POCKETBASE_EMAIL=your_email_here
POCKETBASE_PASSWORD=your_password_here
POCKETBASE_COLLECTION_ACTIVITIES=ayatbot_activites
POCKETBASE_COLLECTION_NOTIFICATIONS=ayatbot_notifications
# Admin username for /notify command
TELEGRAM_ADMIN_USERNAME=your_admin_username
